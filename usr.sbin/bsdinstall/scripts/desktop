  <text x="146" y="610" fill="#94a3b8" font-size="24" font-family="Noto Sans, DejaVu Sans, sans-serif">Rebranded QuiltBSD desktop with aurora wallpaper, QuiltBoot splash, and upgraded motion effects</text>
</svg>
SVG
}

install_user_defaults()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.local/share/quiltbsd
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config/autostart-scripts
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config/autostart
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/Desktop
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/autostart-scripts/quiltbsd-apply-wallpaper.sh" <<'WALL'
#!/bin/sh
wallpaper="/usr/local/share/wallpapers/QuiltBSD/contents/images/1920x1080.svg"
flag="$HOME/.local/share/quiltbsd/wallpaper-applied"
mkdir -p "$HOME/.local/share/quiltbsd"
[ -f "$flag" ] && exit 0
command -v plasma-apply-wallpaperimage >/dev/null 2>&1 || exit 0
plasma-apply-wallpaperimage "$wallpaper" >/dev/null 2>&1 && touch "$flag"
WALL
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/.config/autostart-scripts/quiltbsd-apply-wallpaper.sh"
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.bashrc" <<'BASHRC'
# QuiltBSD interactive shell defaults
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias update-system='sudo pkg update -f && sudo pkg upgrade -f'
alias quiltbsd-postinstall='sudo /usr/local/bin/quiltbsd-postinstall'
alias quiltbsd-welcome='/usr/local/bin/quiltbsd-welcome'
alias pkg-gui='/usr/local/bin/quiltbsd-pkg-gui'
alias pkg-store='/usr/local/bin/quiltbsd-pkg-store'
alias prism='prismlauncher'
BASHRC
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kdeglobals" <<'KDEGLOBALS'
[General]
Name=QuiltBSD Aurora
ColorScheme=BreezeDark

[KDE]
LookAndFeelPackage=org.kde.breezedark.desktop
SingleClick=false

[Icons]
Theme=breeze-dark

[WM]
activeBackground=#1d4ed8
inactiveBackground=#0f172a
KDEGLOBALS
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kwinrc" <<'KWINRC'
[Compositing]
Enabled=true
AnimationSpeed=3
Backend=OpenGL

[Plugins]
blurEnabled=true
desktopchangeosdEnabled=true
fadingpopupsEnabled=true
glideEnabled=true
loginEnabled=true
magiclampEnabled=true
scaleEnabled=true
slidingpopupsEnabled=true
overviewEnabled=true

[TabBox]
LayoutName=thumbnail_grid
KWINRC
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kscreenlockerrc" <<'LOCK'
[Greeter]
WallpaperPlugin=org.kde.image
WallpaperPluginConfig={"Image":"file:///usr/local/share/wallpapers/QuiltBSD/contents/images/1920x1080.svg","FillMode":2}
LOCK
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/dolphinrc" <<'DOLPHIN'
[General]
RememberOpenedTabs=false

[UiSettings]
ColorScheme=BreezeDark
DOLPHIN
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/Firefox.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Firefox
Exec=firefox
Icon=firefox
Terminal=false
Categories=Network;WebBrowser;
DESKTOP
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/LibreOffice.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=LibreOffice
Exec=libreoffice --writer
Icon=libreoffice-startcenter
Terminal=false
Categories=Office;
DESKTOP
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/PrismLauncher.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=PrismLauncher
Exec=prismlauncher
Icon=prismlauncher
Terminal=false
Categories=Game;
DESKTOP
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/Firefox.desktop"
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/LibreOffice.desktop"
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/PrismLauncher.desktop"
}

install_kde_branding()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /etc/sddm.conf.d
	cat > "$BSDINSTALL_CHROOT/etc/sddm.conf.d/quiltbsd-aurora.conf" <<'SDDM'
[General]
DisplayServer=x11
Numlock=on

[Theme]
Current=breeze
CursorTheme=breeze_cursors

[Users]
RememberLastUser=true

[Wayland]
EnableHiDPI=true
SDDM
}

install_pkg_gui()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$PKG_GUI_SCRIPT" <<'PKGGUI'
#!/bin/sh
set -eu

PASSWORD_CACHE=""

prompt_password()
{
	PASSWORD_CACHE=$(zenity --password --title="QuiltBSD PKG GUI") || exit 0
}

run_pkg()
{
	cmd=$1
	while :; do
		[ -n "$PASSWORD_CACHE" ] || prompt_password
		output=$(printf '%s\n' "$PASSWORD_CACHE" | sudo -S sh -c "$cmd" 2>&1) && break
		PASSWORD_CACHE=""
		zenity --error --width=700 --title="QuiltBSD PKG GUI" \
		    --text="Authentication failed or the pkg command returned an error. Retry if needed." --no-wrap
	done
	printf '%s\n' "$output" | zenity --text-info --title="QuiltBSD PKG GUI" --width=900 --height=650
}

prompt_package()
{
	zenity --entry --title="QuiltBSD PKG GUI" --text="Enter package/origin:" --entry-text="$1"
}

prompt_text()
{
	zenity --entry --title="QuiltBSD PKG GUI" --text="$1" --entry-text="$2"
}

while :; do
	choice=$(zenity --list --radiolist \
		--title="QuiltBSD PKG GUI" \
		--width=760 --height=620 \
		--text="Choose a pkg action. For anything else, use Advanced and enter any pkg subcommand you want." \
		--column="Pick" --column="Action" --column="Description" \
		TRUE install "Install a package" \
		FALSE remove "Remove a package" \
		FALSE search "Search packages" \
		FALSE info "Show package info" \
		FALSE update "Run pkg update -f" \
		FALSE upgrade "Run pkg upgrade -f -y" \
		FALSE autoremove "Run pkg autoremove -y" \
		FALSE clean "Run pkg clean -ay" \
		FALSE audit "Run pkg audit -F" \
		FALSE stats "Show pkg stats" \
		FALSE lock "Lock a package" \
		FALSE unlock "Unlock a package" \
		FALSE which "Find which package owns a file" \
		FALSE advanced "Run any custom pkg subcommand" \
		FALSE quit "Exit the GUI") || exit 0

	case "$choice" in
	install)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg install -y $pkgname"
		;;
	remove)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg remove -y $pkgname"
		;;
	search)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg search $pkgname"
		;;
	info)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg info $pkgname"
		;;
	update)
		run_pkg "pkg update -f"
		;;
	upgrade)
		run_pkg "pkg upgrade -f -y"
		;;
	autoremove)
		run_pkg "pkg autoremove -y"
		;;
	clean)
		run_pkg "pkg clean -ay"
		;;
	audit)
		run_pkg "pkg audit -F"
		;;
	stats)
		run_pkg "pkg stats"
		;;
	lock)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg lock -y $pkgname"
		;;
	unlock)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg unlock -y $pkgname"
		;;
	which)
		filepath=$(prompt_text "Enter a filesystem path to query with pkg which:" "/usr/local/bin/firefox") || continue
		[ -n "$filepath" ] || continue
		run_pkg "pkg which $filepath"
		;;
	advanced)
		args=$(prompt_text "Enter any pkg subcommand and arguments:" "search firefox") || continue
		[ -n "$args" ] || continue
		run_pkg "pkg $args"
		;;
	quit)
		exit 0
		;;
	esac
done
PKGGUI
	chmod 0755 "$BSDINSTALL_CHROOT$PKG_GUI_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$PKG_GUI_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD PKG GUI
Comment=Graphical frontend for pkg commands
Exec=/usr/local/bin/quiltbsd-pkg-gui
Icon=system-software-install
Terminal=false
Categories=System;Settings;PackageManager;
DESKTOP
}

