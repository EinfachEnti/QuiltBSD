configure_desktop_environment()
{
	DESKTOP_FLAVOR=kde
	DESKTOP_NAME="KDE Plasma"
	DESKTOP_PACKAGES="x11/plasma6-plasma x11/plasma6-sddm-kcm x11/sddm"
	DISPLAY_MANAGER=sddm
}

install_wallpaper()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$WALLPAPER_DIR"
	cat > "$BSDINSTALL_CHROOT$WALLPAPER_FILE" <<'SVG'
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#050816"/>
      <stop offset="45%" stop-color="#112a6b"/>
      <stop offset="100%" stop-color="#6d28d9"/>
    </linearGradient>
    <linearGradient id="aurora" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#22d3ee"/>
      <stop offset="45%" stop-color="#60a5fa"/>
      <stop offset="100%" stop-color="#f472b6"/>
    </linearGradient>
    <filter id="blur"><feGaussianBlur stdDeviation="20"/></filter>
  </defs>
  <rect width="1920" height="1080" fill="url(#bg)"/>
  <ellipse cx="1450" cy="220" rx="420" ry="120" fill="#67e8f9" fill-opacity="0.16" filter="url(#blur)"/>
  <ellipse cx="530" cy="220" rx="340" ry="90" fill="#c084fc" fill-opacity="0.14" filter="url(#blur)"/>
  <ellipse cx="1020" cy="300" rx="520" ry="110" fill="#f472b6" fill-opacity="0.08" filter="url(#blur)"/>
  <g fill-opacity="0.18">
    <path d="M0 780 L220 600 L440 780 L220 960 Z" fill="#38bdf8"/>
    <path d="M220 600 L440 420 L660 600 L440 780 Z" fill="#818cf8"/>
    <path d="M440 780 L660 600 L880 780 L660 960 Z" fill="#f472b6"/>
    <path d="M880 780 L1100 600 L1320 780 L1100 960 Z" fill="#22d3ee"/>
    <path d="M1320 780 L1540 600 L1760 780 L1540 960 Z" fill="#a78bfa"/>
  </g>
  <path d="M0 840 C 280 720, 520 980, 820 840 S 1460 700, 1920 860 L 1920 1080 L 0 1080 Z" fill="#020617" fill-opacity="0.48"/>
  <text x="140" y="400" fill="#f8fafc" font-size="154" font-family="Noto Sans, DejaVu Sans, sans-serif" font-weight="700">QuiltBSD Aurora</text>
  <text x="146" y="488" fill="url(#aurora)" font-size="46" font-family="Noto Sans, DejaVu Sans, sans-serif">KDE Edition</text>
