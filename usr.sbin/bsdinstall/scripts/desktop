Version=1.0
Name=QuiltPixel
Comment=Local QuiltBSD pixel art studio
Exec=/usr/local/bin/quiltpixel
Icon=applications-graphics
Terminal=false
Categories=Graphics;Utility;
DESKTOP
}

install_pkg_store()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$PKG_STORE_SCRIPT" <<'STORE'
#!/bin/sh
set -eu

PASSWORD_CACHE=""

prompt_password()
{
	PASSWORD_CACHE=$(zenity --password --title="QuiltBSD PKG Store") || exit 0
}

run_pkg()
{
	cmd=$1
	while :; do
		[ -n "$PASSWORD_CACHE" ] || prompt_password
		output=$(printf '%s\n' "$PASSWORD_CACHE" | sudo -S sh -c "$cmd" 2>&1) && break
		PASSWORD_CACHE=""
		zenity --error --width=760 --title="QuiltBSD PKG Store" \
		    --text="Authentication failed or the pkg command returned an error. Retry if needed." --no-wrap
	done
	printf '%s\n' "$output" | zenity --text-info --title="QuiltBSD PKG Store" --width=900 --height=650
}

while :; do
	choice=$(zenity --list --radiolist \
		--title="QuiltBSD PKG Store" \
		--width=980 --height=720 \
		--text="Browse a curated QuiltBSD software store. Pick a package set to install, remove, inspect, or discover the preinstalled essentials." \
		--column="Pick" --column="Package" --column="Category" --column="Name" --column="Description" \
		TRUE "www/firefox" "Web" "Firefox" "Fast default browser" \
		FALSE "multimedia/vlc" "Media" "VLC" "Preinstalled media player" \
		FALSE "editors/vscodium" "Dev" "VS Codium" "Preinstalled code editor" \
		FALSE "devel/git@lite" "Dev" "Git" "Preinstalled version control" \
		FALSE "editors/libreoffice" "Office" "LibreOffice" "Documents, spreadsheets, and presentations" \
		FALSE "games/prismlauncher" "Games" "PrismLauncher" "Minecraft launcher with modpack support" \
		FALSE "graphics/gimp" "Graphics" "GIMP" "Image editing" \
		FALSE "graphics/inkscape" "Graphics" "Inkscape" "Vector illustration" \
		FALSE "net-im/telegram-desktop" "Chat" "Telegram Desktop" "Messaging client" \
		FALSE "net-im/discord" "Chat" "Discord" "Gaming and community chat" \
		FALSE "editors/vscodium" "Dev" "VS Codium" "Code editor without Microsoft branding" \
		FALSE "devel/git@lite" "Dev" "Git" "Distributed version control" \
		FALSE "editors/neovim" "Dev" "Neovim" "Modern Vim-based editor" \
		FALSE "multimedia/audacious" "Audio" "Audacious" "Lightweight music player" \
		FALSE "multimedia/obs-studio" "Utility" "OBS Studio" "Streaming and recording" \
		FALSE "ftp/filezilla" "Utility" "FileZilla" "FTP and SFTP transfers" \
		FALSE "__search__" "Store" "Search manually" "Search the package repository manually" \
		FALSE "__quit__" "Store" "Quit" "Exit the PKG Store") || exit 0

	case "$choice" in
	__quit__)
		exit 0
		;;
	__search__)
		query=$(zenity --entry --title="QuiltBSD PKG Store" \
		    --text="Search the package repository:" --entry-text="browser") || continue
		[ -n "$query" ] || continue
		run_pkg "pkg search $query"
		continue
		;;
	esac

	action=$(zenity --list --radiolist \
		--title="QuiltBSD PKG Store" \
		--width=520 --height=320 \
		--text="What do you want to do with $choice?" \
		--column="Pick" --column="Action" \
		TRUE install \
		FALSE remove \
		FALSE info \
		FALSE search \
		FALSE status) || continue

	case "$action" in
	install) run_pkg "pkg install -y $choice" ;;
	remove) run_pkg "pkg remove -y $choice" ;;
	info) run_pkg "pkg info $choice" ;;
	search) run_pkg "pkg search $choice" ;;
	status) run_pkg "pkg info $choice || echo $choice is not currently installed" ;;
	esac
done
STORE
	chmod 0755 "$BSDINSTALL_CHROOT$PKG_STORE_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$PKG_STORE_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD PKG Store
Comment=Curated software storefront for QuiltBSD packages
Exec=/usr/local/bin/quiltbsd-pkg-store
Icon=system-software-install
Terminal=false
Categories=System;Settings;PackageManager;
DESKTOP
}

install_welcome_screen()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications /usr/share/skel/.config/autostart
	cat > "$BSDINSTALL_CHROOT$WELCOME_SCRIPT" <<'WELCOME'
#!/bin/sh
set -eu

flag="${HOME}/.local/share/quiltbsd/welcome-seen"
mkdir -p "${HOME}/.local/share/quiltbsd"

if [ "${1:-}" != "--force" ] && [ -f "$flag" ]; then
	exit 0
fi

while :; do
	choice=$(zenity --list --radiolist \
		--title="Welcome to QuiltBSD Aurora" \
		--width=880 --height=640 \
		--text="Welcome to QuiltBSD Aurora.\n\nChoose what you want to do next." \
		--column="Pick" --column="Action" --column="Description" \
		TRUE store "Open the QuiltBSD PKG Store" \
		FALSE packages "Open the QuiltBSD PKG GUI" \
		FALSE browser "Launch Firefox" \
		FALSE office "Launch LibreOffice" \
		FALSE prism "Launch PrismLauncher" \
		FALSE code "Launch VS Codium" \
		FALSE media "Launch VLC" \
		FALSE game "Launch QuiltBlaster Multiplayer" \
		FALSE craft "Launch QuiltCraft3D" \
		FALSE notes "Launch QuiltNotes" \
		FALSE pixel "Launch QuiltPixel" \
		FALSE handbook "Open Aurora features overview" \
		FALSE maintenance "Run post-install maintenance" \
		FALSE done "Close and do not show automatically again") || exit 0

	case "$choice" in
	store) /usr/local/bin/quiltbsd-pkg-store ;;
	packages) /usr/local/bin/quiltbsd-pkg-gui ;;
	browser) firefox >/dev/null 2>&1 & ;;
	office) libreoffice >/dev/null 2>&1 & ;;
	prism) prismlauncher >/dev/null 2>&1 & ;;
	code) codium >/dev/null 2>&1 & ;;
	media) vlc >/dev/null 2>&1 & ;;
	game) /usr/local/bin/quiltblaster >/dev/null 2>&1 & ;;
	craft) /usr/local/bin/quiltcraft3d >/dev/null 2>&1 & ;;
	notes) /usr/local/bin/quiltnotes >/dev/null 2>&1 & ;;
	pixel) /usr/local/bin/quiltpixel >/dev/null 2>&1 & ;;
	handbook) zenity --text-info --title="QuiltBSD Aurora Features" --width=900 --height=680 --filename=/usr/local/share/quiltbsd/FEATURES.txt ;;
	maintenance)
		if command -v konsole >/dev/null 2>&1; then
			konsole -e /usr/local/bin/quiltbsd-postinstall >/dev/null 2>&1 &
		elif command -v xterm >/dev/null 2>&1; then
			xterm -e /usr/local/bin/quiltbsd-postinstall >/dev/null 2>&1 &
		else
			zenity --info --title="QuiltBSD Aurora" \
			    --text="Open a terminal and run /usr/local/bin/quiltbsd-postinstall to perform maintenance."
		fi
		;;
	done)
		touch "$flag"
		exit 0
		;;
	esac
done
WELCOME
	chmod 0755 "$BSDINSTALL_CHROOT$WELCOME_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$WELCOME_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD Aurora Welcome
Comment=Welcome screen and first-run launcher for QuiltBSD Aurora
Exec=/usr/local/bin/quiltbsd-welcome --force
Icon=preferences-desktop-theme
Terminal=false
Categories=System;Settings;
DESKTOP
	cat > "$BSDINSTALL_CHROOT$WELCOME_AUTOSTART" <<'AUTOSTART'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD Aurora Welcome
Exec=/usr/local/bin/quiltbsd-welcome
X-GNOME-Autostart-enabled=true
Terminal=false
AUTOSTART
}

install_plymouth_theme()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$PLYMOUTH_THEME_DIR" /usr/local/bin
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_THEME_DIR/quiltboot.plymouth" <<'PLYMOUTH'
[Plymouth Theme]
Name=QuiltBoot
Description=QuiltBoot splash theme
ModuleName=script

[script]
ImageDir=/usr/local/share/plymouth/themes/quiltboot
ScriptFile=/usr/local/share/plymouth/themes/quiltboot/quiltbsd.script
PLYMOUTH
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_THEME_DIR/quiltbsd.script" <<'SCRIPT'
Window.SetBackgroundTopColor (0.02, 0.03, 0.09);
Window.SetBackgroundBottomColor (0.07, 0.16, 0.48);
message = "QuiltBSD Aurora";
progress = 0;
wave = 0;
fun refresh_callback () {
  progress = progress + 0.01;
  if (progress > 1) progress = 0;
  wave = wave + 0.04;
  Window.SetBackgroundTopColor (0.02 + progress * 0.02, 0.03 + progress * 0.10, 0.09 + progress * 0.16);
  Window.SetBackgroundBottomColor (0.07 + progress * 0.02, 0.16 + progress * 0.08, 0.48 + progress * 0.10);
}
Plymouth.SetRefreshFunction (refresh_callback);
SCRIPT
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_HELPER" <<'HELPER'
#!/bin/sh
set -eu
if ! command -v plymouth-set-default-theme >/dev/null 2>&1; then
	echo "plymouth-set-default-theme not found. Install Plymouth support first, then rerun this helper."
	exit 1
fi
plymouth-set-default-theme -R quiltboot
echo "QuiltBoot theme enabled."
HELPER
	chmod 0755 "$BSDINSTALL_CHROOT$PLYMOUTH_HELPER"
	chroot "$BSDINSTALL_CHROOT" sh -c "command -v plymouth-set-default-theme >/dev/null 2>&1 && plymouth-set-default-theme -R quiltboot || true"
}

