.swatch.active { border-color: #f8fafc; }
canvas { image-rendering: pixelated; width: min(80vw, 720px); height: min(80vw, 720px); background: #0f172a; border-radius: 22px; box-shadow: 0 16px 42px rgba(2,6,23,.48); }
#status { color: #67e8f9; min-height: 20px; margin-top: 12px; }
@media (max-width: 920px) { main { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<main>
  <section class="card">
    <h1>QuiltPixel</h1>
    <p>Leichtes Pixel-Studio für Icons, Logos und Wallpaper-Ideen direkt in QuiltBSD. Speichert dein Bild lokal im Browserprofil.</p>
    <div id="palette"></div>
    <input id="customColor" type="color" value="#22c55e" />
    <button id="addColor">Custom Farbe hinzufügen</button>
    <button id="fillBtn">Canvas füllen</button>
    <button id="clearBtn">Canvas leeren</button>
    <button id="saveBtn">Lokal speichern</button>
    <button id="exportBtn">PNG exportieren</button>
    <div id="status"></div>
  </section>
  <section class="card" style="display:flex; justify-content:center; align-items:center;">
    <canvas id="art" width="32" height="32"></canvas>
  </section>
</main>
<script>
const KEY = 'quiltpixel-art-v1';
const paletteEl = document.getElementById('palette');
const statusEl = document.getElementById('status');
const canvas = document.getElementById('art');
const ctx = canvas.getContext('2d');
let colors = ['#22c55e','#38bdf8','#f59e0b','#ef4444','#a855f7','#f8fafc','#0f172a','#f472b6'];
let active = colors[0];
function setStatus(text) { statusEl.textContent = text; setTimeout(() => { if (statusEl.textContent === text) statusEl.textContent = ''; }, 1800); }
function renderPalette() {
  paletteEl.innerHTML = '';
  colors.forEach((color) => {
    const swatch = document.createElement('button');
    swatch.className = `swatch${color === active ? ' active' : ''}`;
    swatch.style.background = color;
    swatch.addEventListener('click', () => { active = color; renderPalette(); });
    paletteEl.appendChild(swatch);
  });
}
function drawPixel(event) {
  const rect = canvas.getBoundingClientRect();
  const x = Math.floor((event.clientX - rect.left) / (rect.width / canvas.width));
  const y = Math.floor((event.clientY - rect.top) / (rect.height / canvas.height));
  ctx.fillStyle = active; ctx.fillRect(x, y, 1, 1);
}
let painting = false;
canvas.addEventListener('mousedown', (event) => { painting = true; drawPixel(event); });
window.addEventListener('mouseup', () => painting = false);
canvas.addEventListener('mousemove', (event) => { if (painting) drawPixel(event); });
document.getElementById('addColor').addEventListener('click', () => {
  const color = document.getElementById('customColor').value;
  if (!colors.includes(color)) colors.push(color);
  active = color; renderPalette(); setStatus('Custom Farbe hinzugefügt');
});
document.getElementById('fillBtn').addEventListener('click', () => { ctx.fillStyle = active; ctx.fillRect(0,0,canvas.width,canvas.height); setStatus('Canvas gefüllt'); });
document.getElementById('clearBtn').addEventListener('click', () => { ctx.clearRect(0,0,canvas.width,canvas.height); setStatus('Canvas geleert'); });
document.getElementById('saveBtn').addEventListener('click', () => { localStorage.setItem(KEY, canvas.toDataURL()); setStatus('Lokal gespeichert'); });
document.getElementById('exportBtn').addEventListener('click', () => { const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'quiltpixel-art.png'; a.click(); setStatus('PNG exportiert'); });
const saved = localStorage.getItem(KEY); if (saved) { const img = new Image(); img.onload = () => ctx.drawImage(img,0,0); img.src = saved; }
renderPalette();
</script>
</body>
</html>
PIXEL
	cat > "$BSDINSTALL_CHROOT$PIXEL_LAUNCHER" <<'LAUNCH'
#!/bin/sh
exec firefox "file:///usr/local/share/quiltbsd/apps/quiltpixel/index.html"
LAUNCH
	chmod 0755 "$BSDINSTALL_CHROOT$PIXEL_LAUNCHER"
	cat > "$BSDINSTALL_CHROOT$PIXEL_DESKTOP" <<'DESKTOP'
