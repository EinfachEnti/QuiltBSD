	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/QuiltBSD Packages.desktop"
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/QuiltBlaster.desktop"
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/QuiltCraft3D.desktop"
