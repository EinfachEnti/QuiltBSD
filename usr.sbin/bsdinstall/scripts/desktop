. $BSDCFG_SHARE/common.subr || exit 1
f_include $BSDCFG_SHARE/dialog.subr

: ${BSDDIALOG_OK=0}
: ${BSDDIALOG_CANCEL=1}

COMMON_PACKAGES="\
	x11/xorg \
	x11/zenity \
	www/firefox \
	editors/libreoffice \
	games/prismlauncher \
	security/sudo \
	shells/bash \
	editors/vim \
	sysutils/tmux \
	net/rsync \
	archivers/unzip \
	archivers/zip\
"
WALLPAPER_DIR="/usr/local/share/wallpapers/QuiltBSD/contents/images"
WALLPAPER_FILE="$WALLPAPER_DIR/1920x1080.svg"
FIRSTBOOT_SCRIPT="/usr/local/libexec/quiltbsd-firstboot-network"
FIRSTBOOT_RC="/usr/local/etc/rc.d/quiltbsd_firstboot_network"
POSTINSTALL_SCRIPT="/usr/local/bin/quiltbsd-postinstall"
PKG_GUI_SCRIPT="/usr/local/bin/quiltbsd-pkg-gui"
PKG_GUI_DESKTOP="/usr/local/share/applications/quiltbsd-pkg-gui.desktop"
PKG_STORE_SCRIPT="/usr/local/bin/quiltbsd-pkg-store"
PKG_STORE_DESKTOP="/usr/local/share/applications/quiltbsd-pkg-store.desktop"
WELCOME_SCRIPT="/usr/local/bin/quiltbsd-welcome"
WELCOME_DESKTOP="/usr/local/share/applications/quiltbsd-welcome.desktop"
WELCOME_AUTOSTART="/usr/share/skel/.config/autostart/quiltbsd-welcome.desktop"
GAME_DIR="/usr/local/share/quiltbsd/games/quiltblaster"
GAME_LAUNCHER="/usr/local/bin/quiltblaster"
GAME_DESKTOP="/usr/local/share/applications/quiltblaster.desktop"
FEATURES_DIR="/usr/local/share/quiltbsd"
FEATURES_FILE="$FEATURES_DIR/FEATURES.txt"
PLYMOUTH_THEME_DIR="/usr/local/share/plymouth/themes/quiltboot"
