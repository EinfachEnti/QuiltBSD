{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /etc/sddm.conf.d
	cat > "$BSDINSTALL_CHROOT/etc/sddm.conf.d/quiltbsd-aurora.conf" <<'SDDM'
[General]
DisplayServer=x11
Numlock=on

[Theme]
Current=breeze
CursorTheme=breeze_cursors

[Users]
RememberLastUser=true

[Wayland]
EnableHiDPI=true
SDDM
}

install_pkg_gui()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$PKG_GUI_SCRIPT" <<'PKGGUI'
#!/bin/sh
set -eu

PASSWORD_CACHE=""

prompt_password()
{
	PASSWORD_CACHE=$(zenity --password --title="QuiltBSD PKG GUI") || exit 0
}

run_pkg()
{
	cmd=$1
	while :; do
		[ -n "$PASSWORD_CACHE" ] || prompt_password
		output=$(printf '%s\n' "$PASSWORD_CACHE" | sudo -S sh -c "$cmd" 2>&1) && break
		PASSWORD_CACHE=""
		zenity --error --width=700 --title="QuiltBSD PKG GUI" \
		    --text="Authentication failed or the pkg command returned an error. Retry if needed." --no-wrap
	done
	printf '%s\n' "$output" | zenity --text-info --title="QuiltBSD PKG GUI" --width=900 --height=650
}

prompt_package()
{
	zenity --entry --title="QuiltBSD PKG GUI" --text="Enter package/origin:" --entry-text="$1"
}

prompt_text()
{
	zenity --entry --title="QuiltBSD PKG GUI" --text="$1" --entry-text="$2"
}

while :; do
	choice=$(zenity --list --radiolist \
		--title="QuiltBSD PKG GUI" \
		--width=760 --height=620 \
		--text="Choose a pkg action. For anything else, use Advanced and enter any pkg subcommand you want." \
		--column="Pick" --column="Action" --column="Description" \
		TRUE install "Install a package" \
		FALSE remove "Remove a package" \
		FALSE search "Search packages" \
		FALSE info "Show package info" \
		FALSE update "Run pkg update -f" \
		FALSE upgrade "Run pkg upgrade -f -y" \
		FALSE autoremove "Run pkg autoremove -y" \
		FALSE clean "Run pkg clean -ay" \
		FALSE audit "Run pkg audit -F" \
		FALSE stats "Show pkg stats" \
		FALSE lock "Lock a package" \
		FALSE unlock "Unlock a package" \
		FALSE which "Find which package owns a file" \
		FALSE advanced "Run any custom pkg subcommand" \
		FALSE quit "Exit the GUI") || exit 0

	case "$choice" in
	install)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg install -y $pkgname"
		;;
	remove)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg remove -y $pkgname"
		;;
	search)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg search $pkgname"
		;;
	info)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg info $pkgname"
		;;
	update)
		run_pkg "pkg update -f"
		;;
	upgrade)
		run_pkg "pkg upgrade -f -y"
		;;
	autoremove)
		run_pkg "pkg autoremove -y"
		;;
	clean)
		run_pkg "pkg clean -ay"
		;;
	audit)
		run_pkg "pkg audit -F"
		;;
	stats)
		run_pkg "pkg stats"
		;;
	lock)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg lock -y $pkgname"
		;;
	unlock)
		pkgname=$(prompt_package "firefox") || continue
		[ -n "$pkgname" ] || continue
		run_pkg "pkg unlock -y $pkgname"
		;;
	which)
		filepath=$(prompt_text "Enter a filesystem path to query with pkg which:" "/usr/local/bin/firefox") || continue
		[ -n "$filepath" ] || continue
		run_pkg "pkg which $filepath"
		;;
	advanced)
		args=$(prompt_text "Enter any pkg subcommand and arguments:" "search firefox") || continue
		[ -n "$args" ] || continue
		run_pkg "pkg $args"
		;;
	quit)
		exit 0
		;;
	esac
done
PKGGUI
	chmod 0755 "$BSDINSTALL_CHROOT$PKG_GUI_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$PKG_GUI_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD PKG GUI
Comment=Graphical frontend for pkg commands
Exec=/usr/local/bin/quiltbsd-pkg-gui
Icon=system-software-install
Terminal=false
Categories=System;Settings;PackageManager;
DESKTOP
}

install_game()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$GAME_DIR" /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$GAME_DIR/index.html" <<'GAME'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>QuiltBlaster Multiplayer</title>
<style>
body { margin: 0; background: radial-gradient(circle at top, #1e3a8a, #020617 55%); color: #e2e8f0; font-family: sans-serif; overflow: hidden; }
#hud { position: fixed; top: 12px; left: 12px; right: 12px; display: flex; justify-content: space-between; z-index: 2; font-size: 14px; text-shadow: 0 0 6px #000; }
#help { position: fixed; bottom: 12px; left: 12px; z-index: 2; font-size: 13px; max-width: 560px; background: rgba(15,23,42,.55); padding: 8px 10px; border-radius: 10px; }
#crosshair { position: fixed; left: 50%; top: 50%; width: 18px; height: 18px; margin-left: -9px; margin-top: -9px; z-index: 2; }
#crosshair::before, #crosshair::after { content: ""; position: absolute; background: #f8fafc; }
#crosshair::before { left: 8px; top: 0; width: 2px; height: 18px; }
#crosshair::after { left: 0; top: 8px; width: 18px; height: 2px; }
#minimap { position: fixed; right: 16px; bottom: 16px; width: 180px; height: 180px; border: 2px solid rgba(255,255,255,.25); background: rgba(2,6,23,.55); z-index: 2; }
#flash { position: fixed; inset: 0; pointer-events: none; background: radial-gradient(circle at center, rgba(255,255,255,.20), transparent 45%); opacity: 0; transition: opacity .12s linear; z-index: 3; }
canvas { display: block; width: 100vw; height: 100vh; }
</style>
</head>
<body>
<div id="hud">
  <div><strong>QuiltBlaster Multiplayer</strong> — View <span id="view">P1</span> — Wave <span id="wave">1</span> — Ammo <span id="ammo">12</span></div>
  <div>P1 HP <span id="hp1">100</span> | P2 HP <span id="hp2">100</span> | Score <span id="score">0</span> | Enemies <span id="enemies">0</span></div>
</div>
<div id="crosshair"></div>
<div id="flash"></div>
<div id="help">P1: WASD + Pfeile + Leertaste + R. P2: IJKL + U/O + Enter + P. V wechselt die Kamera. Boss alle 3 Wellen. Klick startet neu.</div>
<canvas id="game" width="960" height="540"></canvas>
<canvas id="minimap" width="180" height="180"></canvas>
<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
const minimap = document.getElementById("minimap");
const mctx = minimap.getContext("2d");
const flash = document.getElementById("flash");
const hud = {
  view: document.getElementById("view"),
  wave: document.getElementById("wave"),
  hp1: document.getElementById("hp1"),
  hp2: document.getElementById("hp2"),
  ammo: document.getElementById("ammo"),
  score: document.getElementById("score"),
  enemies: document.getElementById("enemies"),
};
const map = [
  "################",
  "#..............#",
  "#..##..E.......#",
  "#..............#",
  "#......####....#",
  "#..............#",
  "#....E.........#",
  "#..............#",
  "#.........##...#",
  "#..............#",
  "#...####.......#",
  "#...........E..#",
  "#..............#",
  "#......P.......#",
  "#..............#",
  "################",
];
const fov = Math.PI / 3;
const keys = {};
let enemies = [];
let shots = [];
let players = [];
let score;
let wave;
let lastTime = 0;
let running = false;
let flashTimer = 0;
let skyOffset = 0;
let activeView = 0;

function makePlayer(name, x, y, angle, color, controls) {
  return {
    name,
    x,
    y,
    angle,
    hp: 100,
    ammo: 12,
    maxAmmo: 12,
    reloadTimer: 0,
    color,
    controls,
  };
}

function currentPlayer() {
  return players[activeView] || players[0];
}

function resetGame() {
  enemies = [];
  shots = [];
  score = 0;
  wave = 1;
  flashTimer = 0;
  skyOffset = 0;
  activeView = 0;
  players = [
    makePlayer("P1", 7.5, 13.5, -Math.PI / 2, "#38bdf8", {
      forward: "w", back: "s", left: "a", right: "d",
      turnLeft: "arrowleft", turnRight: "arrowright",
      shoot: " ", reload: "r", sprint: "shift"
    }),
    makePlayer("P2", 8.8, 13.5, -Math.PI / 2, "#f472b6", {
      forward: "i", back: "k", left: "j", right: "l",
      turnLeft: "u", turnRight: "o",
      shoot: "enter", reload: "p", sprint: "n"
    }),
  ];
  spawnWave();
  running = true;
}

function spawnWave() {
  const spawnPoints = [];
  for (let y = 0; y < map.length; y++) {
    for (let x = 0; x < map[y].length; x++) {
      if (map[y][x] === "E") spawnPoints.push({ x: x + 0.5, y: y + 0.5 });
    }
  }
  const count = Math.min(spawnPoints.length, 2 + wave);
  enemies = spawnPoints.slice(0, count).map((p, i) => ({
    x: p.x + (i % 2) * 0.2,
    y: p.y + (i % 3) * 0.15,
    alive: true,
    cooldown: Math.random() * 1.5,
    hp: 1,
    boss: false,
  }));
  if (wave % 3 === 0 && enemies.length) {
    enemies[0].boss = true;
    enemies[0].hp = 4 + wave;
  }
}

function isWall(x, y) {
  const gx = Math.floor(x), gy = Math.floor(y);
  if (gy < 0 || gy >= map.length || gx < 0 || gx >= map[0].length) return true;
  return map[gy][gx] === "#";
}

function castRay(angle) {
  const player = currentPlayer();
  let distance = 0;
  while (distance < 20) {
    const x = player.x + Math.cos(angle) * distance;
    const y = player.y + Math.sin(angle) * distance;
    if (isWall(x, y)) return distance;
    distance += 0.02;
  }
  return 20;
}

function reload() {
	const player = currentPlayer();
	if (!player) return;
	if (player.reloadTimer > 0 || player.ammo === player.maxAmmo) return;
	player.reloadTimer = 1.1;
}

function update(dt) {
  if (!running) return;
  if (flashTimer > 0) flashTimer = Math.max(0, flashTimer - dt * 6);
  skyOffset += dt * 18;
  players.forEach((player) => {
    if (player.hp <= 0) return;
    if (player.reloadTimer > 0) {
      player.reloadTimer -= dt;
      if (player.reloadTimer <= 0) player.ammo = player.maxAmmo;
    }
    const sprint = keys[player.controls.sprint] ? 1.7 : 1;
    const moveSpeed = 2.2 * dt * sprint;
    const turnSpeed = 1.9 * dt;
    if (keys[player.controls.turnLeft]) player.angle -= turnSpeed;
    if (keys[player.controls.turnRight]) player.angle += turnSpeed;
    let dx = 0, dy = 0;
    if (keys[player.controls.forward]) { dx += Math.cos(player.angle) * moveSpeed; dy += Math.sin(player.angle) * moveSpeed; }
    if (keys[player.controls.back]) { dx -= Math.cos(player.angle) * moveSpeed; dy -= Math.sin(player.angle) * moveSpeed; }
    if (keys[player.controls.left]) { dx += Math.cos(player.angle - Math.PI / 2) * moveSpeed; dy += Math.sin(player.angle - Math.PI / 2) * moveSpeed; }
    if (keys[player.controls.right]) { dx += Math.cos(player.angle + Math.PI / 2) * moveSpeed; dy += Math.sin(player.angle + Math.PI / 2) * moveSpeed; }
    if (!isWall(player.x + dx, player.y)) player.x += dx;
    if (!isWall(player.x, player.y + dy)) player.y += dy;
  });

  enemies.forEach((enemy) => {
    if (!enemy.alive) return;
    const livePlayers = players.filter((p) => p.hp > 0);
    if (!livePlayers.length) {
      running = false;
      return;
    }
    const target = livePlayers.sort((a, b) =>
      Math.hypot(a.x - enemy.x, a.y - enemy.y) - Math.hypot(b.x - enemy.x, b.y - enemy.y))[0];
    const angleToPlayer = Math.atan2(target.y - enemy.y, target.x - enemy.x);
    const dist = Math.hypot(target.x - enemy.x, target.y - enemy.y);
    const speed = enemy.boss ? 0.45 : 0.8;
    if (dist > 0.8) {
      const ex = enemy.x + Math.cos(angleToPlayer) * dt * speed;
      const ey = enemy.y + Math.sin(angleToPlayer) * dt * speed;
      if (!isWall(ex, enemy.y)) enemy.x = ex;
      if (!isWall(enemy.x, ey)) enemy.y = ey;
    }
    enemy.cooldown -= dt;
    if (dist < 1.2 && enemy.cooldown <= 0) {
      target.hp = Math.max(0, target.hp - (enemy.boss ? 16 : 8));
      enemy.cooldown = enemy.boss ? 0.8 : 1.0;
      if (players.every((p) => p.hp <= 0)) running = false;
    }
  });

  shots = shots.filter((shot) => {
    shot.life -= dt;
    return shot.life > 0;
  });

  if (enemies.every((e) => !e.alive)) {
    wave += 1;
    spawnWave();
  }
}

function shoot() {
  const player = currentPlayer();
  fireForPlayer(player);
}

function fireForPlayer(player) {
  if (!running || !player || player.hp <= 0 || player.reloadTimer > 0) return;
  if (player.ammo <= 0) {
    const previousView = activeView;
    activeView = players.indexOf(player);
    reload();
    activeView = previousView;
    return;
  }
  player.ammo -= 1;
  flashTimer = 1;
  shots.push({ life: 0.08 });
  let best = null;
  enemies.forEach((enemy) => {
    if (!enemy.alive) return;
    const dx = enemy.x - player.x;
    const dy = enemy.y - player.y;
    const dist = Math.hypot(dx, dy);
    const ang = Math.atan2(dy, dx);
    let diff = ang - player.angle;
    while (diff < -Math.PI) diff += Math.PI * 2;
    while (diff > Math.PI) diff -= Math.PI * 2;
    if (Math.abs(diff) < 0.12 && (!best || dist < best.dist)) best = { enemy, dist };
  });
  if (best) {
    best.enemy.hp -= 1;
    if (best.enemy.hp <= 0) {
      best.enemy.alive = false;
      score += best.enemy.boss ? 500 : 100;
    }
  }
}

function renderMinimap() {
  const scale = minimap.width / map[0].length;
  mctx.fillStyle = "rgba(2,6,23,.92)";
  mctx.fillRect(0, 0, minimap.width, minimap.height);
  for (let y = 0; y < map.length; y++) {
    for (let x = 0; x < map[y].length; x++) {
      mctx.fillStyle = map[y][x] === "#" ? "#334155" : "#0f172a";
      mctx.fillRect(x * scale, y * scale, scale - 1, scale - 1);
    }
  }
  enemies.filter((e) => e.alive).forEach((enemy) => {
    mctx.fillStyle = enemy.boss ? "#f59e0b" : "#ef4444";
    mctx.beginPath();
    mctx.arc(enemy.x * scale, enemy.y * scale, enemy.boss ? 5 : 3, 0, Math.PI * 2);
    mctx.fill();
  });
  players.forEach((player) => {
    if (player.hp <= 0) return;
    mctx.fillStyle = player.color;
    mctx.beginPath();
    mctx.arc(player.x * scale, player.y * scale, 4, 0, Math.PI * 2);
    mctx.fill();
  });
}

function render() {
  const w = canvas.width, h = canvas.height;
  const player = currentPlayer();
  const sky = ctx.createLinearGradient(0, 0, 0, h / 2);
  sky.addColorStop(0, "#1d4ed8");
  sky.addColorStop(1, "#0f172a");
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, w, h / 2);
  ctx.fillStyle = "#111827";
  ctx.fillRect(0, h / 2, w, h / 2);
  for (let i = 0; i < 18; i++) {
    const starX = ((i * 79) + skyOffset * (i % 3 + 1)) % w;
    const starY = 40 + (i * 23) % (h / 2 - 50);
    ctx.fillStyle = `rgba(255,255,255,${0.25 + (i % 4) * 0.12})`;
    ctx.fillRect(starX, starY, 2, 2);
  }

  for (let x = 0; x < w; x++) {
    const rayAngle = player.angle - fov / 2 + (x / w) * fov;
    const distance = castRay(rayAngle);
    const corrected = distance * Math.cos(rayAngle - player.angle);
    const wallHeight = Math.min(h, h / Math.max(corrected, 0.001));
    const shade = Math.max(40, 220 - corrected * 22);
    ctx.fillStyle = `rgb(${shade * 0.25}, ${shade * 0.45}, ${shade})`;
    ctx.fillRect(x, h / 2 - wallHeight / 2, 1, wallHeight);
  }

  enemies
    .filter((e) => e.alive)
    .map((enemy) => {
      const dx = enemy.x - player.x;
      const dy = enemy.y - player.y;
      const dist = Math.hypot(dx, dy);
      let ang = Math.atan2(dy, dx) - player.angle;
      while (ang < -Math.PI) ang += Math.PI * 2;
      while (ang > Math.PI) ang -= Math.PI * 2;
      return { enemy, dist, ang };
    })
    .filter((s) => Math.abs(s.ang) < fov / 1.5)
    .sort((a, b) => b.dist - a.dist)
    .forEach((sprite) => {
      const size = Math.max(12, (sprite.enemy.boss ? 420 : 260) / sprite.dist);
      const sx = (sprite.ang / fov + 0.5) * w;
      const sy = h / 2 + Math.sin(lastTime / 160 + sprite.dist) * (sprite.enemy.boss ? 18 : 10);
      ctx.fillStyle = sprite.enemy.boss ? "#f59e0b" : "#ef4444";
      ctx.beginPath();
      ctx.arc(sx, sy, size / 2, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = "#f8fafc";
      ctx.fillRect(sx - 8, sy - 4, 4, 4);
      ctx.fillRect(sx + 4, sy - 4, 4, 4);
    });

  if (shots.length) {
    ctx.strokeStyle = "#fde68a";
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(w / 2, h / 2);
    ctx.lineTo(w / 2, h / 2 - 40);
    ctx.stroke();
  }
  flash.style.opacity = flashTimer > 0 ? String(flashTimer * 0.65) : "0";

  if (!running) {
    ctx.fillStyle = "rgba(2,6,23,.75)";
    ctx.fillRect(0, 0, w, h);
    ctx.fillStyle = "#f8fafc";
    ctx.font = "bold 34px sans-serif";
    ctx.fillText(players.every((p) => p.hp <= 0) ? "Game Over" : "QuiltBlaster Multiplayer", w / 2 - 180, h / 2 - 10);
    ctx.font = "20px sans-serif";
    ctx.fillText("Klick zum Starten / Neustarten", w / 2 - 125, h / 2 + 28);
  }

  renderMinimap();
  hud.view.textContent = players[activeView].name;
  hud.wave.textContent = wave;
  hud.hp1.textContent = Math.max(0, Math.round(players[0].hp));
  hud.hp2.textContent = Math.max(0, Math.round(players[1].hp));
  hud.ammo.textContent = player.reloadTimer > 0 ? "..." : player.ammo;
  hud.score.textContent = score;
  hud.enemies.textContent = enemies.filter((e) => e.alive).length;
}

function loop(ts) {
  const dt = Math.min(0.033, (ts - lastTime) / 1000 || 0);
  lastTime = ts;
  update(dt);
  render();
  requestAnimationFrame(loop);
}

window.addEventListener("keydown", (e) => {
  const key = e.key.toLowerCase();
  keys[key] = true;
  if (e.code === "Space") fireForPlayer(players[0]);
  if (e.key === "Enter") fireForPlayer(players[1]);
  if (key === "r") { activeView = 0; reload(); }
  if (key === "p") { activeView = 1; reload(); }
  if (key === "v") activeView = activeView === 0 ? 1 : 0;
});
window.addEventListener("keyup", (e) => {
  keys[e.key.toLowerCase()] = false;
});
window.addEventListener("click", () => {
  if (!running) resetGame();
});

resetGame();
requestAnimationFrame(loop);
</script>
</body>
</html>
GAME
	cat > "$BSDINSTALL_CHROOT$GAME_LAUNCHER" <<'LAUNCH'
#!/bin/sh
exec firefox "file:///usr/local/share/quiltbsd/games/quiltblaster/index.html"
LAUNCH
	chmod 0755 "$BSDINSTALL_CHROOT$GAME_LAUNCHER"
	cat > "$BSDINSTALL_CHROOT$GAME_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBlaster Multiplayer
Comment=Local QuiltBSD multiplayer arena shooter
Exec=/usr/local/bin/quiltblaster
Icon=applications-games
Terminal=false
Categories=Game;ActionGame;
DESKTOP
}

install_pkg_store()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$PKG_STORE_SCRIPT" <<'STORE'
#!/bin/sh
set -eu

PASSWORD_CACHE=""

prompt_password()
{
	PASSWORD_CACHE=$(zenity --password --title="QuiltBSD PKG Store") || exit 0
}

run_pkg()
{
	cmd=$1
	while :; do
		[ -n "$PASSWORD_CACHE" ] || prompt_password
		output=$(printf '%s\n' "$PASSWORD_CACHE" | sudo -S sh -c "$cmd" 2>&1) && break
		PASSWORD_CACHE=""
		zenity --error --width=760 --title="QuiltBSD PKG Store" \
		    --text="Authentication failed or the pkg command returned an error. Retry if needed." --no-wrap
	done
	printf '%s\n' "$output" | zenity --text-info --title="QuiltBSD PKG Store" --width=900 --height=650
}

while :; do
	choice=$(zenity --list --radiolist \
		--title="QuiltBSD PKG Store" \
		--width=980 --height=720 \
		--text="Browse a curated QuiltBSD software store. Pick a package set to install, remove, or inspect." \
		--column="Pick" --column="Package" --column="Category" --column="Name" --column="Description" \
		TRUE "www/firefox" "Web" "Firefox" "Fast default browser" \
		FALSE "editors/libreoffice" "Office" "LibreOffice" "Documents, spreadsheets, and presentations" \
		FALSE "games/prismlauncher" "Games" "PrismLauncher" "Minecraft launcher with modpack support" \
		FALSE "multimedia/vlc" "Media" "VLC" "Versatile video and audio player" \
		FALSE "graphics/gimp" "Graphics" "GIMP" "Image editing" \
		FALSE "graphics/inkscape" "Graphics" "Inkscape" "Vector illustration" \
		FALSE "net-im/telegram-desktop" "Chat" "Telegram Desktop" "Messaging client" \
		FALSE "net-im/discord" "Chat" "Discord" "Gaming and community chat" \
		FALSE "editors/vscodium" "Dev" "VS Codium" "Code editor without Microsoft branding" \
		FALSE "devel/git@lite" "Dev" "Git" "Distributed version control" \
		FALSE "editors/neovim" "Dev" "Neovim" "Modern Vim-based editor" \
		FALSE "multimedia/audacious" "Audio" "Audacious" "Lightweight music player" \
		FALSE "multimedia/obs-studio" "Utility" "OBS Studio" "Streaming and recording" \
		FALSE "ftp/filezilla" "Utility" "FileZilla" "FTP and SFTP transfers" \
		FALSE "__search__" "Store" "Search manually" "Search the package repository manually" \
		FALSE "__quit__" "Store" "Quit" "Exit the PKG Store") || exit 0

	case "$choice" in
	__quit__)
		exit 0
		;;
	__search__)
		query=$(zenity --entry --title="QuiltBSD PKG Store" \
		    --text="Search the package repository:" --entry-text="browser") || continue
		[ -n "$query" ] || continue
		run_pkg "pkg search $query"
		continue
		;;
	esac

	action=$(zenity --list --radiolist \
		--title="QuiltBSD PKG Store" \
		--width=520 --height=320 \
		--text="What do you want to do with $choice?" \
		--column="Pick" --column="Action" \
		TRUE install \
		FALSE remove \
		FALSE info \
		FALSE search) || continue

	case "$action" in
	install) run_pkg "pkg install -y $choice" ;;
	remove) run_pkg "pkg remove -y $choice" ;;
	info) run_pkg "pkg info $choice" ;;
	search) run_pkg "pkg search $choice" ;;
	esac
done
STORE
	chmod 0755 "$BSDINSTALL_CHROOT$PKG_STORE_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$PKG_STORE_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD PKG Store
Comment=Curated software storefront for QuiltBSD packages
Exec=/usr/local/bin/quiltbsd-pkg-store
Icon=system-software-install
Terminal=false
Categories=System;Settings;PackageManager;
DESKTOP
}

install_welcome_screen()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/local/bin /usr/local/share/applications /usr/share/skel/.config/autostart
	cat > "$BSDINSTALL_CHROOT$WELCOME_SCRIPT" <<'WELCOME'
#!/bin/sh
set -eu

flag="${HOME}/.local/share/quiltbsd/welcome-seen"
mkdir -p "${HOME}/.local/share/quiltbsd"

if [ "${1:-}" != "--force" ] && [ -f "$flag" ]; then
	exit 0
fi

while :; do
	choice=$(zenity --list --radiolist \
		--title="Welcome to QuiltBSD Aurora" \
		--width=880 --height=640 \
		--text="Welcome to QuiltBSD Aurora.\n\nChoose what you want to do next." \
		--column="Pick" --column="Action" --column="Description" \
		TRUE store "Open the QuiltBSD PKG Store" \
		FALSE packages "Open the QuiltBSD PKG GUI" \
		FALSE browser "Launch Firefox" \
		FALSE office "Launch LibreOffice" \
		FALSE prism "Launch PrismLauncher" \
		FALSE game "Launch QuiltBlaster Multiplayer" \
		FALSE handbook "Open Aurora features overview" \
		FALSE maintenance "Run post-install maintenance" \
		FALSE done "Close and do not show automatically again") || exit 0

	case "$choice" in
	store) /usr/local/bin/quiltbsd-pkg-store ;;
	packages) /usr/local/bin/quiltbsd-pkg-gui ;;
	browser) firefox >/dev/null 2>&1 & ;;
	office) libreoffice >/dev/null 2>&1 & ;;
	prism) prismlauncher >/dev/null 2>&1 & ;;
	game) /usr/local/bin/quiltblaster >/dev/null 2>&1 & ;;
	handbook) zenity --text-info --title="QuiltBSD Aurora Features" --width=900 --height=680 --filename=/usr/local/share/quiltbsd/FEATURES.txt ;;
	maintenance)
		if command -v konsole >/dev/null 2>&1; then
			konsole -e /usr/local/bin/quiltbsd-postinstall >/dev/null 2>&1 &
		elif command -v xterm >/dev/null 2>&1; then
			xterm -e /usr/local/bin/quiltbsd-postinstall >/dev/null 2>&1 &
		else
			zenity --info --title="QuiltBSD Aurora" \
			    --text="Open a terminal and run /usr/local/bin/quiltbsd-postinstall to perform maintenance."
		fi
		;;
	done)
		touch "$flag"
		exit 0
		;;
	esac
done
WELCOME
	chmod 0755 "$BSDINSTALL_CHROOT$WELCOME_SCRIPT"
	cat > "$BSDINSTALL_CHROOT$WELCOME_DESKTOP" <<'DESKTOP'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD Aurora Welcome
Comment=Welcome screen and first-run launcher for QuiltBSD Aurora
Exec=/usr/local/bin/quiltbsd-welcome --force
Icon=preferences-desktop-theme
Terminal=false
Categories=System;Settings;
DESKTOP
	cat > "$BSDINSTALL_CHROOT$WELCOME_AUTOSTART" <<'AUTOSTART'
[Desktop Entry]
Type=Application
Version=1.0
Name=QuiltBSD Aurora Welcome
Exec=/usr/local/bin/quiltbsd-welcome
X-GNOME-Autostart-enabled=true
Terminal=false
AUTOSTART
}

install_plymouth_theme()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$PLYMOUTH_THEME_DIR" /usr/local/bin
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_THEME_DIR/quiltboot.plymouth" <<'PLYMOUTH'
[Plymouth Theme]
Name=QuiltBoot
Description=QuiltBoot splash theme
ModuleName=script

[script]
ImageDir=/usr/local/share/plymouth/themes/quiltboot
ScriptFile=/usr/local/share/plymouth/themes/quiltboot/quiltbsd.script
PLYMOUTH
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_THEME_DIR/quiltbsd.script" <<'SCRIPT'
Window.SetBackgroundTopColor (0.02, 0.03, 0.09);
Window.SetBackgroundBottomColor (0.07, 0.16, 0.48);
message = "QuiltBSD Aurora";
progress = 0;
wave = 0;
fun refresh_callback () {
  progress = progress + 0.01;
  if (progress > 1) progress = 0;
  wave = wave + 0.04;
  Window.SetBackgroundTopColor (0.02 + progress * 0.02, 0.03 + progress * 0.10, 0.09 + progress * 0.16);
  Window.SetBackgroundBottomColor (0.07 + progress * 0.02, 0.16 + progress * 0.08, 0.48 + progress * 0.10);
}
Plymouth.SetRefreshFunction (refresh_callback);
SCRIPT
	cat > "$BSDINSTALL_CHROOT$PLYMOUTH_HELPER" <<'HELPER'
#!/bin/sh
set -eu
if ! command -v plymouth-set-default-theme >/dev/null 2>&1; then
	echo "plymouth-set-default-theme not found. Install Plymouth support first, then rerun this helper."
	exit 1
fi
plymouth-set-default-theme -R quiltboot
echo "QuiltBoot theme enabled."
HELPER
	chmod 0755 "$BSDINSTALL_CHROOT$PLYMOUTH_HELPER"
	chroot "$BSDINSTALL_CHROOT" sh -c "command -v plymouth-set-default-theme >/dev/null 2>&1 && plymouth-set-default-theme -R quiltboot || true"
}

