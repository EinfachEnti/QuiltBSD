<body>
<div id="hud">
  <div class="panel"><div class="label">World</div><div class="value">QuiltCraft3D Sandbox</div><div>Seed <strong id="seed">AURORA</strong></div></div>
  <div class="panel"><div class="label">Builder</div><div>Blocks <strong id="blocksPlaced">0</strong></div><div>Removed <strong id="blocksRemoved">0</strong></div></div>
  <div class="panel"><div class="label">Position</div><div>X <strong id="posX">0</strong> Y <strong id="posY">0</strong> Z <strong id="posZ">0</strong></div></div>
</div>
<div id="tips" class="panel">WASD bewegen, Maus ziehen zum Schauen, Leertaste hoch, Shift runter, 1-4 Material wechseln, Linksklick Block setzen, Rechtsklick Block abbauen, R Welt neu generieren.</div>
<div id="toolbar"></div>
<div id="crosshair"></div>
<div id="message">Block platziert</div>
<canvas id="view" width="1280" height="720"></canvas>
<div id="overlay">
  <div id="startCard">
    <h1>QuiltCraft3D</h1>
    <p>Ein lokaler Minecraft-Klon für QuiltBSD: baue Blöcke, forme Inseln und experimentiere in einer prozeduralen Voxel-Sandbox direkt auf dem Desktop.</p>
    <p><strong>Steuerung:</strong> Klicken oder Enter startet die Welt. Nutze 1-4 für Gras, Stein, Quiltium und Glas.</p>
  </div>
</div>
<script>
const canvas = document.getElementById('view');
const ctx = canvas.getContext('2d');
const overlay = document.getElementById('overlay');
const toolbar = document.getElementById('toolbar');
const message = document.getElementById('message');
const stats = {
  blocksPlaced: document.getElementById('blocksPlaced'),
  blocksRemoved: document.getElementById('blocksRemoved'),
  posX: document.getElementById('posX'),
  posY: document.getElementById('posY'),
  posZ: document.getElementById('posZ'),
};
const materials = [
  { name: 'Grass', color: '#22c55e', top: '#4ade80' },
  { name: 'Stone', color: '#94a3b8', top: '#cbd5e1' },
  { name: 'Quiltium', color: '#a855f7', top: '#e879f9' },
  { name: 'Glass', color: '#38bdf8', top: '#bfdbfe' },
];
const world = new Map();
const size = 22;
const keys = {};
let pointerLocked = false;
let selected = 0;
let placed = 0;
let removed = 0;
let started = false;
let messageTimer = 0;
const camera = { x: 0, y: 5.5, z: 0, yaw: 0.8, pitch: -0.45, velY: 0 };

function keyFor(x, y, z) { return `${x},${y},${z}`; }
function setBlock(x, y, z, type) { world.set(keyFor(x, y, z), type); }
function getBlock(x, y, z) { return world.get(keyFor(x, y, z)); }
function removeBlock(x, y, z) { world.delete(keyFor(x, y, z)); }
function showMessage(text) {
  message.textContent = text;
  message.classList.add('show');
  messageTimer = 1.4;
}
function buildToolbar() {
  toolbar.innerHTML = '';
  materials.forEach((material, index) => {
    const div = document.createElement('div');
    div.className = `slot${index === selected ? ' active' : ''}`;
    div.innerHTML = `<div>${index + 1}</div><strong>${material.name}</strong>`;
    toolbar.appendChild(div);
  });
}
function generateWorld() {
  world.clear();
  placed = 0;
  removed = 0;
  for (let x = -size; x <= size; x++) {
    for (let z = -size; z <= size; z++) {
      const height = Math.max(1, Math.floor(2 + Math.sin(x * 0.45) * 1.4 + Math.cos(z * 0.38) * 1.6 + Math.sin((x + z) * 0.25) * 1.2));
      for (let y = -1; y < height; y++) {
        setBlock(x, y, z, y === height - 1 ? 0 : 1);
      }
      if ((x + z) % 11 === 0 && height > 2) {
        setBlock(x, height, z, 2);
      }
    }
  }
  camera.x = 0;
  camera.y = 7;
  camera.z = 0;
  camera.velY = 0;
  showMessage('Neue QuiltCraft3D-Welt generiert');
}
function project(x, y, z) {
  const dx = x - camera.x;
  const dy = y - camera.y;
  const dz = z - camera.z;
  const cosY = Math.cos(-camera.yaw), sinY = Math.sin(-camera.yaw);
  const rx = dx * cosY - dz * sinY;
  const rz = dx * sinY + dz * cosY;
  const cosP = Math.cos(-camera.pitch), sinP = Math.sin(-camera.pitch);
  const ry = dy * cosP - rz * sinP;
  const rz2 = dy * sinP + rz * cosP;
  if (rz2 <= 0.15) return null;
  const scale = 720 / rz2;
  return { x: canvas.width / 2 + rx * scale, y: canvas.height / 2 - ry * scale, depth: rz2, scale };
}
function isoPoint(x, y, z) {
  const p = project(x, y, z);
  return p ? [p.x, p.y, p.depth] : null;
}
function faceVisible(normal) {
  const view = [Math.sin(camera.yaw) * Math.cos(camera.pitch), Math.sin(camera.pitch), Math.cos(camera.yaw) * Math.cos(camera.pitch)];
  return normal[0] * view[0] + normal[1] * view[1] + normal[2] * view[2] < 0;
}
function drawFace(points, fill, stroke) {
  ctx.beginPath();
  ctx.moveTo(points[0][0], points[0][1]);
  for (let i = 1; i < points.length; i++) ctx.lineTo(points[i][0], points[i][1]);
  ctx.closePath();
  ctx.fillStyle = fill;
  ctx.fill();
  ctx.strokeStyle = stroke;
  ctx.stroke();
}
function gatherFaces() {
  const faces = [];
  for (const [key, type] of world.entries()) {
    const [x, y, z] = key.split(',').map(Number);
    const corners = {
      ftl: isoPoint(x, y + 1, z), ftr: isoPoint(x + 1, y + 1, z), fbl: isoPoint(x, y, z), fbr: isoPoint(x + 1, y, z),
      btl: isoPoint(x, y + 1, z + 1), btr: isoPoint(x + 1, y + 1, z + 1), bbl: isoPoint(x, y, z + 1), bbr: isoPoint(x + 1, y, z + 1),
    };
    if (Object.values(corners).some((point) => !point)) continue;
    const material = materials[type] || materials[0];
    const defs = [
      { points: [corners.ftl, corners.ftr, corners.btr, corners.btl], normal: [0, 1, 0], fill: material.top, stroke: 'rgba(255,255,255,.16)' },
      { points: [corners.ftr, corners.fbr, corners.bbr, corners.btr], normal: [1, 0, 0], fill: material.color, stroke: 'rgba(15,23,42,.65)' },
      { points: [corners.btl, corners.btr, corners.bbr, corners.bbl], normal: [0, 0, 1], fill: material.color, stroke: 'rgba(15,23,42,.72)' },
    ];
    defs.forEach((face) => {
      if (!faceVisible(face.normal)) return;
      faces.push({ points: face.points, fill: face.fill, stroke: face.stroke, depth: face.points.reduce((sum, point) => sum + point[2], 0) / face.points.length });
    });
  }
  faces.sort((a, b) => b.depth - a.depth);
  return faces;
}
function updateStats() {
  stats.blocksPlaced.textContent = placed;
  stats.blocksRemoved.textContent = removed;
  stats.posX.textContent = camera.x.toFixed(1);
  stats.posY.textContent = camera.y.toFixed(1);
  stats.posZ.textContent = camera.z.toFixed(1);
}
function modifyBlock(place) {
  const targetX = Math.round(camera.x + Math.sin(camera.yaw) * 3);
  const targetY = Math.max(0, Math.round(camera.y + Math.sin(-camera.pitch) * 2 - 1));
  const targetZ = Math.round(camera.z + Math.cos(camera.yaw) * 3);
  if (place) {
    setBlock(targetX, targetY, targetZ, selected);
    placed += 1;
    showMessage(`${materials[selected].name} gesetzt`);
  } else if (getBlock(targetX, targetY, targetZ) !== undefined) {
    removeBlock(targetX, targetY, targetZ);
    removed += 1;
    showMessage('Block entfernt');
  }
}
function update(dt) {
  const speed = keys['shift'] ? 7.2 : 4.2;
  const forwardX = Math.sin(camera.yaw);
  const forwardZ = Math.cos(camera.yaw);
  const rightX = Math.sin(camera.yaw + Math.PI / 2);
  const rightZ = Math.cos(camera.yaw + Math.PI / 2);
  if (keys['w']) { camera.x += forwardX * speed * dt; camera.z += forwardZ * speed * dt; }
  if (keys['s']) { camera.x -= forwardX * speed * dt; camera.z -= forwardZ * speed * dt; }
  if (keys['a']) { camera.x -= rightX * speed * dt; camera.z -= rightZ * speed * dt; }
  if (keys['d']) { camera.x += rightX * speed * dt; camera.z += rightZ * speed * dt; }
  if (keys[' ']) camera.y += 4.5 * dt;
  if (keys['shift']) camera.y -= 2.8 * dt;
  camera.y = Math.max(2.5, Math.min(14, camera.y));
  if (messageTimer > 0) {
    messageTimer -= dt;
    if (messageTimer <= 0) message.classList.remove('show');
  }
}
function renderBackground() {
  const sky = ctx.createLinearGradient(0, 0, 0, canvas.height);
  sky.addColorStop(0, '#0f172a');
  sky.addColorStop(0.48, '#1d4ed8');
  sky.addColorStop(1, '#111827');
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = 'rgba(255,255,255,.16)';
  for (let i = 0; i < 28; i++) ctx.fillRect((i * 97) % canvas.width, (i * 53) % (canvas.height * 0.6), 2, 2);
}
function render() {
  renderBackground();
  const faces = gatherFaces();
  ctx.lineWidth = 1;
  faces.forEach((face) => drawFace(face.points, face.fill, face.stroke));
  updateStats();
  buildToolbar();
}
let lastTime = 0;
function loop(ts) {
  const dt = Math.min(0.033, (ts - lastTime) / 1000 || 0);
  lastTime = ts;
  if (started) update(dt);
  render();
  requestAnimationFrame(loop);
}
window.addEventListener('keydown', (event) => {
  const key = event.key.toLowerCase();
  keys[key] = true;
  if (/^[1-4]$/.test(key)) selected = Number(key) - 1;
  if (key === 'r') generateWorld();
  if (event.key === 'Enter' && !started) start();
});
window.addEventListener('keyup', (event) => {
  keys[event.key.toLowerCase()] = false;
});
window.addEventListener('mousemove', (event) => {
  if (!pointerLocked) return;
  camera.yaw += event.movementX * 0.0028;
  camera.pitch = Math.max(-1.1, Math.min(0.6, camera.pitch + event.movementY * 0.0022));
});
window.addEventListener('click', (event) => {
  if (!started) { start(); return; }
  if (!pointerLocked) canvas.requestPointerLock();
  if (event.button === 0) modifyBlock(true);
});
window.addEventListener('contextmenu', (event) => {
  event.preventDefault();
  if (started) modifyBlock(false);
});
document.addEventListener('pointerlockchange', () => {
  pointerLocked = document.pointerLockElement === canvas;
});
function resize() {
  const ratio = window.devicePixelRatio || 1;
  canvas.width = Math.floor(window.innerWidth * ratio);
  canvas.height = Math.floor(window.innerHeight * ratio);
  canvas.style.width = `${window.innerWidth}px`;
  canvas.style.height = `${window.innerHeight}px`;
  ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
}
function start() {
  started = true;
  overlay.classList.add('hidden');
  canvas.requestPointerLock?.();
  showMessage('Willkommen in QuiltCraft3D');
}
resize();
generateWorld();
requestAnimationFrame(loop);
window.addEventListener('resize', resize);
</script>
</body>
</html>
