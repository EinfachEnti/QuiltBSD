PLYMOUTH_THEME_DIR="/usr/local/share/plymouth/themes/quiltboot"
PLYMOUTH_HELPER="/usr/local/bin/quiltboot-enable"
DESKTOP_FLAVOR=
DESKTOP_NAME=
DESKTOP_PACKAGES=
DISPLAY_MANAGER=
DESKTOP_SENTINEL="/var/db/quiltbsd-aurora-desktop.installed"

configure_desktop_environment()
{
	DESKTOP_FLAVOR=kde
	DESKTOP_NAME="KDE Plasma"
	DESKTOP_PACKAGES="x11/plasma6-plasma x11/plasma6-sddm-kcm x11/sddm"
	DISPLAY_MANAGER=sddm
}

install_wallpaper()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$WALLPAPER_DIR"
	cat > "$BSDINSTALL_CHROOT$WALLPAPER_FILE" <<'SVG'
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#050816"/>
      <stop offset="45%" stop-color="#112a6b"/>
      <stop offset="100%" stop-color="#6d28d9"/>
    </linearGradient>
    <linearGradient id="aurora" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#22d3ee"/>
      <stop offset="45%" stop-color="#60a5fa"/>
      <stop offset="100%" stop-color="#f472b6"/>
    </linearGradient>
    <filter id="blur"><feGaussianBlur stdDeviation="20"/></filter>
  </defs>
  <rect width="1920" height="1080" fill="url(#bg)"/>
  <ellipse cx="1450" cy="220" rx="420" ry="120" fill="#67e8f9" fill-opacity="0.16" filter="url(#blur)"/>
  <ellipse cx="530" cy="220" rx="340" ry="90" fill="#c084fc" fill-opacity="0.14" filter="url(#blur)"/>
  <ellipse cx="1020" cy="300" rx="520" ry="110" fill="#f472b6" fill-opacity="0.08" filter="url(#blur)"/>
  <g fill-opacity="0.18">
    <path d="M0 780 L220 600 L440 780 L220 960 Z" fill="#38bdf8"/>
    <path d="M220 600 L440 420 L660 600 L440 780 Z" fill="#818cf8"/>
    <path d="M440 780 L660 600 L880 780 L660 960 Z" fill="#f472b6"/>
    <path d="M880 780 L1100 600 L1320 780 L1100 960 Z" fill="#22d3ee"/>
    <path d="M1320 780 L1540 600 L1760 780 L1540 960 Z" fill="#a78bfa"/>
  </g>
  <path d="M0 840 C 280 720, 520 980, 820 840 S 1460 700, 1920 860 L 1920 1080 L 0 1080 Z" fill="#020617" fill-opacity="0.48"/>
  <text x="140" y="400" fill="#f8fafc" font-size="154" font-family="Noto Sans, DejaVu Sans, sans-serif" font-weight="700">QuiltBSD Aurora</text>
  <text x="146" y="488" fill="url(#aurora)" font-size="46" font-family="Noto Sans, DejaVu Sans, sans-serif">KDE Edition</text>
  <text x="146" y="555" fill="#cbd5e1" font-size="32" font-family="Noto Sans, DejaVu Sans, sans-serif">Firefox, LibreOffice, PrismLauncher, package tools, and first-boot refresh included</text>
  <text x="146" y="610" fill="#94a3b8" font-size="24" font-family="Noto Sans, DejaVu Sans, sans-serif">Rebranded QuiltBSD desktop with aurora wallpaper, QuiltBoot splash, and upgraded motion effects</text>
</svg>
SVG
}

install_user_defaults()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.local/share/quiltbsd
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config/autostart-scripts
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/.config/autostart
	chroot "$BSDINSTALL_CHROOT" mkdir -p /usr/share/skel/Desktop
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/autostart-scripts/quiltbsd-apply-wallpaper.sh" <<'WALL'
#!/bin/sh
wallpaper="/usr/local/share/wallpapers/QuiltBSD/contents/images/1920x1080.svg"
flag="$HOME/.local/share/quiltbsd/wallpaper-applied"
mkdir -p "$HOME/.local/share/quiltbsd"
[ -f "$flag" ] && exit 0
command -v plasma-apply-wallpaperimage >/dev/null 2>&1 || exit 0
plasma-apply-wallpaperimage "$wallpaper" >/dev/null 2>&1 && touch "$flag"
WALL
	chmod 0755 "$BSDINSTALL_CHROOT/usr/share/skel/.config/autostart-scripts/quiltbsd-apply-wallpaper.sh"
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.bashrc" <<'BASHRC'
# QuiltBSD interactive shell defaults
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias update-system='sudo pkg update -f && sudo pkg upgrade -f'
alias quiltbsd-postinstall='sudo /usr/local/bin/quiltbsd-postinstall'
alias quiltbsd-welcome='/usr/local/bin/quiltbsd-welcome'
alias pkg-gui='/usr/local/bin/quiltbsd-pkg-gui'
alias pkg-store='/usr/local/bin/quiltbsd-pkg-store'
alias prism='prismlauncher'
alias quiltblaster='/usr/local/bin/quiltblaster'
alias quiltcraft='/usr/local/bin/quiltcraft3d'
alias quiltnotes='/usr/local/bin/quiltnotes'
alias quiltpixel='/usr/local/bin/quiltpixel'
alias aurora-tour='/usr/local/bin/quiltbsd-feature-tour'
BASHRC
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kdeglobals" <<'KDEGLOBALS'
[General]
Name=QuiltBSD Aurora
ColorScheme=BreezeDark

[KDE]
LookAndFeelPackage=org.kde.breezedark.desktop
SingleClick=false

[Icons]
Theme=breeze-dark

[WM]
activeBackground=#1d4ed8
inactiveBackground=#0f172a
KDEGLOBALS
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kwinrc" <<'KWINRC'
[Compositing]
Enabled=true
AnimationSpeed=3
Backend=OpenGL

[Plugins]
blurEnabled=true
desktopchangeosdEnabled=true
fadingpopupsEnabled=true
glideEnabled=true
loginEnabled=true
magiclampEnabled=true
scaleEnabled=true
slidingpopupsEnabled=true
overviewEnabled=true

[TabBox]
LayoutName=thumbnail_grid
KWINRC
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/kscreenlockerrc" <<'LOCK'
[Greeter]
WallpaperPlugin=org.kde.image
WallpaperPluginConfig={"Image":"file:///usr/local/share/wallpapers/QuiltBSD/contents/images/1920x1080.svg","FillMode":2}
LOCK
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/.config/dolphinrc" <<'DOLPHIN'
[General]
RememberOpenedTabs=false

[UiSettings]
ColorScheme=BreezeDark
DOLPHIN
	cat > "$BSDINSTALL_CHROOT/usr/share/skel/Desktop/Firefox.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Firefox
Exec=firefox
Icon=firefox
Terminal=false
Categories=Network;WebBrowser;
