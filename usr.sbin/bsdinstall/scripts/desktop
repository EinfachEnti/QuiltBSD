install_quiltnotes()
{
	chroot "$BSDINSTALL_CHROOT" mkdir -p "$NOTES_DIR" /usr/local/bin /usr/local/share/applications
	cat > "$BSDINSTALL_CHROOT$NOTES_DIR/index.html" <<'NOTES'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>QuiltNotes</title>
<style>
:root { color-scheme: dark; }
body {
  margin: 0;
  font-family: Inter, "Noto Sans", system-ui, sans-serif;
  background: linear-gradient(160deg, #020617, #111827 48%, #1d4ed8);
  color: #e2e8f0;
}
header, main { max-width: 1180px; margin: 0 auto; padding: 20px; }
header h1 { margin-bottom: 8px; }
.grid { display: grid; grid-template-columns: 320px 1fr; gap: 18px; }
.card {
  background: rgba(15, 23, 42, 0.82);
  border: 1px solid rgba(96, 165, 250, 0.2);
  border-radius: 18px;
  padding: 16px;
  box-shadow: 0 16px 40px rgba(2, 6, 23, 0.35);
}
label { display: block; font-size: 13px; color: #93c5fd; margin: 12px 0 6px; }
input, textarea, select, button {
  width: 100%; border-radius: 12px; border: 1px solid rgba(148,163,184,.18);
  background: rgba(15,23,42,.78); color: #f8fafc; padding: 10px 12px; box-sizing: border-box;
}
textarea { min-height: 220px; resize: vertical; }
button { cursor: pointer; background: linear-gradient(90deg, #2563eb, #7c3aed); font-weight: 700; }
.button-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
.button-row button { flex: 1; min-width: 140px; }
#notes { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
.note {
  padding: 16px; border-radius: 16px; min-height: 180px; background: rgba(15, 23, 42, 0.84);
  border: 1px solid rgba(148,163,184,.16); position: relative;
}
.note h3 { margin: 0 0 8px; }
.note p { white-space: pre-wrap; color: #cbd5e1; }
.meta { font-size: 12px; color: #94a3b8; margin-bottom: 8px; }
.note .tag { display: inline-block; margin-right: 8px; margin-top: 10px; padding: 4px 8px; border-radius: 999px; background: rgba(56,189,248,.12); color: #7dd3fc; }
.note .actions { display: flex; gap: 10px; margin-top: 12px; }
.note .actions button { flex: 1; padding: 8px; }
#status { color: #67e8f9; min-height: 20px; margin-top: 8px; }
@media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<header>
  <h1>QuiltNotes</h1>
  <p>Lokale Notizen-, Roadmap- und Ideen-Zentrale für QuiltBSD. Speichert alles direkt im Browserprofil mit Tags, Prioritäten und JSON-Export.</p>
</header>
<main class="grid">
  <section class="card">
    <h2>Notiz bearbeiten</h2>
    <label for="title">Titel</label>
    <input id="title" placeholder="z. B. Release-Ideen" />
    <label for="tags">Tags</label>
    <input id="tags" placeholder="aurora, todo, design" />
    <label for="priority">Priorität</label>
    <select id="priority">
      <option>Critical</option><option>High</option><option selected>Normal</option><option>Low</option>
    </select>
    <label for="body">Inhalt</label>
    <textarea id="body" placeholder="Schreibe deine Ideen, Checklisten oder Patch-Notizen hier hinein."></textarea>
    <div class="button-row">
      <button id="saveBtn">Notiz speichern</button>
      <button id="clearBtn" type="button">Editor leeren</button>
    </div>
    <div class="button-row">
      <button id="exportBtn" type="button">JSON exportieren</button>
      <button id="importBtn" type="button">Demo laden</button>
    </div>
    <div id="status"></div>
  </section>
  <section class="card">
    <h2>Notizwand</h2>
    <div id="notes"></div>
  </section>
</main>
<script>
const KEY = 'quilt-notes-v1';
let editingId = null;
const el = {
  title: document.getElementById('title'), tags: document.getElementById('tags'), priority: document.getElementById('priority'),
  body: document.getElementById('body'), notes: document.getElementById('notes'), status: document.getElementById('status'),
};
function loadNotes() { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
function saveNotes(notes) { localStorage.setItem(KEY, JSON.stringify(notes)); }
function setStatus(text) { el.status.textContent = text; setTimeout(() => { if (el.status.textContent === text) el.status.textContent = ''; }, 1800); }
function resetEditor() { editingId = null; el.title.value = ''; el.tags.value = ''; el.priority.value = 'Normal'; el.body.value = ''; }
function render() {
  const notes = loadNotes().sort((a,b) => b.updatedAt - a.updatedAt);
  el.notes.innerHTML = notes.map((note) => `
    <article class="note">
      <div class="meta">${new Date(note.updatedAt).toLocaleString()} · ${note.priority}</div>
      <h3>${note.title}</h3>
      <p>${note.body}</p>
      <div>${note.tags.split(',').filter(Boolean).map((tag) => `<span class="tag">#${tag.trim()}</span>`).join('')}</div>
      <div class="actions">
        <button onclick="editNote('${note.id}')">Bearbeiten</button>
        <button onclick="deleteNote('${note.id}')">Löschen</button>
      </div>
    </article>`).join('') || '<p>Noch keine Notizen gespeichert.</p>';
}
window.editNote = function(id) {
  const note = loadNotes().find((entry) => entry.id === id);
  if (!note) return;
  editingId = id;
  el.title.value = note.title;
  el.tags.value = note.tags;
  el.priority.value = note.priority;
  el.body.value = note.body;
  setStatus('Notiz in den Editor geladen');
};
window.deleteNote = function(id) {
  saveNotes(loadNotes().filter((entry) => entry.id !== id));
  if (editingId === id) resetEditor();
  render();
  setStatus('Notiz gelöscht');
};
document.getElementById('saveBtn').addEventListener('click', () => {
  const title = el.title.value.trim() || 'Ohne Titel';
  const body = el.body.value.trim();
  const tags = el.tags.value.trim();
  const priority = el.priority.value;
  const notes = loadNotes();
  const note = { id: editingId || crypto.randomUUID(), title, body, tags, priority, updatedAt: Date.now() };
  const idx = notes.findIndex((entry) => entry.id === note.id);
  if (idx >= 0) notes[idx] = note; else notes.push(note);
  saveNotes(notes); render(); resetEditor(); setStatus('Notiz gespeichert');
});
document.getElementById('clearBtn').addEventListener('click', () => { resetEditor(); setStatus('Editor geleert'); });
document.getElementById('exportBtn').addEventListener('click', () => {
  const blob = new Blob([JSON.stringify(loadNotes(), null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob); const a = document.createElement('a');
  a.href = url; a.download = 'quiltnotes-export.json'; a.click(); URL.revokeObjectURL(url);
  setStatus('Export gestartet');
});
document.getElementById('importBtn').addEventListener('click', () => {
  saveNotes([
    { id: crypto.randomUUID(), title: 'Aurora Roadmap', body: '• PKG Store weiter ausbauen\n• Neue Quilt Apps polishen\n• Installer Branding finalisieren', tags: 'roadmap,aurora', priority: 'High', updatedAt: Date.now() },
    { id: crypto.randomUUID(), title: 'QuiltCraft Ideen', body: 'Biomes, save slots, ambient soundtrack, crafting loop', tags: 'game,quiltcraft', priority: 'Normal', updatedAt: Date.now() - 60000 },
  ]);
  render(); setStatus('Demo-Notizen geladen');
});
render();
</script>
</body>
</html>
